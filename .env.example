# Confluence
CONFLUENCE_URL=https://your-confluence.example.com
CONFLUENCE_USERNAME=your-username
# Confluence Server/Data Center: account password. Confluence Cloud: use API token below.
CONFLUENCE_PASSWORD=
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_PARENT_PAGE_ID=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_PAGE_IDS=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=confluence_pages_e5_v1
QDRANT_HNSW_M=
QDRANT_HNSW_EF_CONSTRUCT=
# Temporary low threshold for small collections; revisit after HNSW benchmarks.
QDRANT_HNSW_FULL_SCAN_THRESHOLD=10
QDRANT_HNSW_EF_SEARCH=128
ATTACHMENT_SAMPLE_DIR=data/attachment_samples

# Retrieval
# Final top-k after reranking
RETRIEVAL_TOP_K=10
# Candidate pool sizes before merge/dedup (not final top-k)
RETRIEVAL_BM25_LIMIT=50
RETRIEVAL_VECTOR_LIMIT=50
# Cross-encoder: BAAI/bge-reranker-v2-m3 (default) or cross-encoder/ms-marco-MiniLM-L-6-v2
# Preset aliases: bge_m3, ms_marco
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Cross-encoder batch size (leave empty to use sentence-transformers default = 32)
RERANKER_BATCH_SIZE=

# Embeddings
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_VECTOR_SIZE=768

# Logging
LOG_LEVEL=INFO

# Agent workflow
RAGUE_CHAT_MODEL=gpt-4o-mini
RAGUE_MAX_REWRITES=2
RAGUE_CHAT_TEMPERATURE=0
RAGUE_CHAT_TIMEOUT=60
RAGUE_CHAT_MAX_RETRIES=2
RAGUE_AGENT_STREAMING=0
# RAGUE_AGENT_DEBUG=1
# RAGUE_RUN_AGENT_INTEGRATION=1

# OpenAI-compatible LLM backend
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
